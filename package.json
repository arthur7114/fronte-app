{
    "name": "super",
    "version": "0.1.0",
    "private": true,
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "dev": "turbo dev",
        "build": "turbo build",
        "lint": "turbo lint",
        "typecheck": "turbo typecheck",
        "dev:web": "turbo dev --filter=@super/web",
        "dev:worker": "turbo dev --filter=@super/worker",
        "build:web": "turbo build --filter=@super/web",
        "build:worker": "turbo build --filter=@super/worker",
        "start": "npm run start:web",
        "start:web": "npm --workspace @super/web run start",
        "start:worker": "npm --workspace @super/worker run start"
    },
    "devDependencies": {
        "dotenv": "^17.4.2",
        "turbo": "^2",
        "typescript": "^5.7"
    },
    "packageManager": "npm@10.9.2",
    "engines": {
        "node": ">=20"
    },
    "dependencies": {
        "postgres": "^3.4.9"
    }
}
