# ================================================
# Super - Environment Variables
# ================================================
# Copy this file to .env and fill in the values.
# In this monorepo, `apps/web` and `apps/worker` can read envs from the repo root `.env`
# and `.env.local`. The worker can also override with `apps/worker/.env.local`.

# App
APP_NAME=Super
APP_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase (server-side / worker)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# AI Providers (optional - tenants can configure their own)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
